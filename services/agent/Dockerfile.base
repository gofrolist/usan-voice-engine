# syntax=docker/dockerfile:1.7-labs
FROM python:3.12-slim@sha256:090ba77e2958f6af52a5341f788b50b032dd4ca28377d2893dcf1ecbdfdfe203 AS base

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_CACHE_DIR=/app/.uv-cache \
    HF_HOME=/app/.hf_cache \
    HOME=/app

# System deps: ca-certificates for HTTPS model downloads. ffmpeg + libsndfile1
# were removed — PyAV (av) statically bundles its own FFmpeg libs and nothing in
# the venv dynamically links system ffmpeg/libsndfile (verified via ldd), so they
# were ~150-250MB of dead weight.
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:0.11.16@sha256:440fd6477af86a2f1b38080c539f1672cd22acb1b1a47e321dba5158ab08864d /uv /usr/local/bin/uv

WORKDIR /app

# Create the non-root user up front and hand it /app, so the venv, uv cache and
# pre-warmed HF model cache are all WRITTEN owned by appuser. The thin app image
# can then skip a recursive `chown -R /app` that would otherwise copy-up
# (duplicate) the whole venv + ~460MB model cache into a fresh layer.
RUN groupadd -g 1001 appuser && \
    useradd  -u 1001 -g 1001 -s /sbin/nologin -d /app appuser && \
    chown appuser:appuser /app
USER appuser

# Install deps first for cache-friendliness (cache mount owned by appuser).
COPY --chown=appuser:appuser pyproject.toml uv.lock ./
RUN --mount=type=cache,target=/app/.uv-cache,uid=1001,gid=1001 \
    uv sync --frozen --no-install-project --no-dev

# Pre-warm models so the first call doesn't pay the download cost:
# - Silero VAD: small, loads on import via VAD.load()
# - Turn detector: downloads ONNX weights via download-files
# Runs as appuser so HF_HOME is born appuser-owned (the worker can write HF
# lock/revision files at runtime as the non-root user). An optional HF token
# (BuildKit secret `hf_token`, supplied by CI) authenticates the downloads to
# dodge the anonymous-IP 429 rate limits; local `make base` builds fall back to
# anonymous downloads (token stays empty).
RUN --mount=type=secret,id=hf_token,uid=1001 \
    --mount=type=cache,target=/app/.uv-cache,uid=1001,gid=1001 \
    export HF_TOKEN="$(cat /run/secrets/hf_token 2>/dev/null || true)" && \
    export HUGGING_FACE_HUB_TOKEN="$HF_TOKEN" && \
    uv run python -c "from livekit.plugins import silero; silero.VAD.load()" && \
    uv run python -m livekit.agents download-files
