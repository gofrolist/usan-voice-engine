# syntax=docker/dockerfile:1.7-labs
FROM python:3.12-slim AS base

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    UV_LINK_MODE=copy \
    HF_HOME=/app/.hf_cache

# System deps for audio (ffmpeg, libsndfile for Silero) and model downloads
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg libsndfile1 ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:0.5.11 /uv /usr/local/bin/uv

WORKDIR /app

COPY pyproject.toml uv.lock ./
RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --frozen --no-install-project --no-dev

# Pre-warm models so first call doesn't pay download cost.
# - Silero VAD: small, loads on import via VAD.load()
# - Turn detector: downloads ONNX weights via download-files command
RUN uv run python -c "from livekit.plugins import silero; silero.VAD.load()" && \
    uv run python -m livekit.agents download-files
