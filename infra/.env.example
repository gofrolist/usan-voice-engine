# === Postgres ===
POSTGRES_USER=usan
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=usan
DATABASE_URL=postgresql://usan:change-me-locally@postgres:5432/usan

# === LiveKit SFU ===
# Generate with: openssl rand -hex 32
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret-replace-with-32-char-random-string
LIVEKIT_URL=ws://livekit:7880

# === Cartesia (STT + TTS) ===
CARTESIA_API_KEY=
# Pick a warm, slow voice from https://play.cartesia.ai/voices
DEFAULT_CARTESIA_VOICE_ID=

# === Vertex AI (LLM; HIPAA-BAA-covered) ===
# No API key — the agent uses ADC via the VM's attached service account.
# "global": gemini-3.1-flash-lite is served on the global endpoint, not regional.
# The Admin Studio agent text-test (POST /v1/admin/profiles/{id}/test/llm) ALSO
# reads these (the API now calls Vertex via ADC for that path), so the API's
# service account needs roles/aiplatform.user. These keys already ship to the VM
# for the agent; no new secret is introduced. (spec 001-retellai-parity-admin)
GCP_PROJECT=usan-retirement
VERTEX_LOCATION=global

# === Admin Studio — voice samples (Cartesia TTS) ===
# The voice-sample proxy (GET /v1/admin/voice-catalog/{id}/sample) reuses the
# CARTESIA_API_KEY above (server-side; the browser never calls Cartesia). These
# three are optional with the defaults shown. ORDERING: any new key must reach the
# VM `.env` BEFORE the deploy tag is cut (the tag deploy does not re-fetch secrets).
# CARTESIA_API_URL=https://api.cartesia.ai
# CARTESIA_VERSION=2024-11-13
# CARTESIA_SAMPLE_MODEL=sonic-2

# === Telnyx (SIP trunk) ===
TELNYX_SIP_USERNAME=
TELNYX_SIP_PASSWORD=
TELNYX_SIP_HOST=sip.telnyx.com
TELNYX_INBOUND_DID=                   # e.g. +14155551234

# === Misc ===
LOG_LEVEL=INFO

# === Operator/management API plane ===
# Authenticates the operator endpoints (/v1/elders, /v1/dnc, /v1/calls).
# Required (min 32 chars) — left blank so an unedited .env fails fast at startup
# rather than booting with a guessable key. Generate with: openssl rand -hex 32
OPERATOR_API_KEY=
# Serve OpenAPI docs (/docs, /redoc). Handy in dev; turn OFF in production.
DOCS_ENABLED=true
# Per-client request rate limiting (slowapi). Disable only for local debugging.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60/minute
# Reject webhooks whose signed timestamp is older than this many seconds.
# WEBHOOK_MAX_AGE_S=300
# PHI retention purge horizon in days. Leave UNSET to disable the retention
# purge entirely (no automatic deletion of elder/call PHI).
# PHI_RETENTION_DAYS=90

# === Agent ===
AGENT_NAME=usan-agent

# === Outbound calling ===
# The API auto-provisions (or reuses) a LiveKit SIP outbound trunk named
# usan-telnyx-outbound from the Telnyx SIP credentials above on the first
# outbound dial — no manual trunk creation needed. Leave this BLANK for that.
# Set it only to PIN a specific trunk ID (ST_xxxxxxxx) and skip auto-provisioning.
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=
# Optional: override the auto-provisioned trunk's name (default usan-telnyx-outbound).
# LIVEKIT_OUTBOUND_TRUNK_NAME=usan-telnyx-outbound
# E.164 number Telnyx presents as caller ID on outbound calls (your purchased DID).
TELNYX_CALLER_ID=
# --- Telnyx Messaging (Phase 3 send_sms; feature-flagged OFF by default) ---
# SMS is never sent unless TELNYX_MESSAGING_ENABLED=true AND the three values below
# are set. Bodies may use non-PHI variables only (enforced at save).
TELNYX_MESSAGING_ENABLED=false
TELNYX_MESSAGING_API_KEY=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_FROM_NUMBER=                   # E.164, e.g. +14155551234
TELNYX_MESSAGING_API_URL=https://api.telnyx.com/v2   # must be https:// (validated at startup)
TELNYX_MESSAGING_TIMEOUT_S=10        # per-request timeout for the messaging POST (1-60)
# Seconds to wait for the callee to answer before the dial is marked no_answer (5-120).
# OUTBOUND_RINGING_TIMEOUT_S=45
# Max seconds an answered call may run before LiveKit ends it (60-7200).
# OUTBOUND_MAX_CALL_DURATION_S=1800

# === Call recording (LiveKit Egress -> GCS) ===
# GCS bucket for recordings. Leave BLANK to disable recording (the dev default —
# the agent skips egress and GET /v1/calls returns no signed URL).
GCS_BUCKET=
# TTL (seconds) for signed recording URLs from GET /v1/calls/{id} (60-604800).
# RECORDING_SIGNED_URL_TTL_S=3600

# === Service-to-service auth (agent -> api) ===
# Shared HS256 key the agent signs callbacks with and the API verifies.
# Required (min 32 chars) — left blank so an unedited .env fails fast at startup
# rather than booting with a guessable key. Generate with: openssl rand -hex 32
JWT_SIGNING_KEY=
# Base URL the agent uses to reach the API (compose network service name).
API_BASE_URL=http://api:8000
# Note: the agent-side answer timeout is no longer an env var. It is now driven by
# the published agent config (agent_config TimingConfig.answer_timeout_s), resolved
# per call at start. The former OUTBOUND_ANSWER_TIMEOUT_S setting was removed.

# === Retry orchestrator (in-process Postgres poller) ===
# Re-dials no_answer/voicemail_left/busy/failed calls per the §5.3 policy, gated
# by TCPA quiet hours (09:00-21:00 in the elder's local timezone). All optional;
# defaults shown.
# Seconds between poll cycles (5-300).
# RETRY_POLL_INTERVAL_S=30
# Max rows claimed per cycle (1-200).
# RETRY_BATCH_SIZE=20
# Re-queue a retry stranded in 'dialing' after this many seconds (must exceed the
# ring timeout; 120-3600).
# RETRY_STUCK_DIALING_S=300
# Set to false to disable the poller on a given replica (e.g. run it on only one).
# RETRY_POLLER_ENABLED=true

# === Batch & scheduled calling ===
# Recurring per-elder CallSchedule rows + one-off CallBatch campaigns materialize
# ordinary Call rows into the retry-poller dial path. All optional; settings
# defaults shown (the dev compose file flips both feature flags ON for local
# testing; prod ships them OFF).
# Master switch for the schedule/batch poller; false = no autonomous materialization.
# Invariant (startup-validated, spec §10.3): true requires CONCURRENCY_GATE_ENABLED=true.
# SCHEDULER_POLLER_ENABLED=false
# Seconds between scheduler poll cycles (15-600).
# SCHEDULER_POLL_INTERVAL_S=60
# Max schedule rows / batch targets claimed per cycle (1-500).
# SCHEDULER_BATCH_SIZE=50
# Global concurrency gate on poller-claimed dials; no-op when false (gauges still export).
# CONCURRENCY_GATE_ENABLED=false
# Hard cap on simultaneous calls (1-50); sized for the e2-standard-4 VM — measure before raising.
# MAX_CONCURRENT_CALLS=8
# Slots held back for ad-hoc/inbound calls (0-20; must stay < MAX_CONCURRENT_CALLS).
# RESERVED_CONCURRENCY=2
# Autonomous-call ceiling per elder per elder-local day (1-10): daily schedule + one campaign.
# MAX_AUTONOMOUS_CALLS_PER_ELDER_PER_DAY=2
# Emergency stop: true halts every poller-claimed dial; state-preserving and reversible.
# AUTONOMOUS_DIALING_PAUSED=false

# === Outbound event webhooks (spec 2026-06-10) ===
# Signed HMAC-SHA256 POSTs of call-lifecycle events (call.started, call.completed,
# flag.created, callback.created, batch.completed) to operator-registered HTTPS
# endpoints. NAMESPACE NOTE: WEBHOOK_MAX_AGE_S above is the INBOUND LiveKit
# webhook verification window; every OUTBOUND delivery key carries the disjoint
# WEBHOOK_DELIVERY_ prefix. All optional; settings defaults shown (the dev compose
# file flips the delivery flag ON so POST .../test works locally; prod ships it OFF).
# Master switch for the delivery half of the poller (housekeeping always runs).
# WEBHOOK_DELIVERY_ENABLED=false
# Seconds between delivery poll cycles (5-300).
# WEBHOOK_DELIVERY_POLL_INTERVAL_S=10
# Per-delivery POST timeout in seconds (1-60).
# WEBHOOK_DELIVERY_TIMEOUT_S=10
# Consecutive failures before the circuit breaker auto-disables an endpoint (1-100).
# WEBHOOK_DELIVERY_CIRCUIT_BREAKER_THRESHOLD=10

# === Admin UI — Google SSO (dev) ===
# The admin SPA (apps/admin-ui) runs via `npm run dev` (Vite, proxies /v1 -> this
# API). SSO is OFF until you set a Google OAuth client. Over local http the session
# cookie cannot be Secure, so set SESSION_COOKIE_SECURE=false for local login.
SESSION_COOKIE_SECURE=false
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/v1/auth/callback
# ADMIN_BOOTSTRAP_EMAILS=you@example.com
