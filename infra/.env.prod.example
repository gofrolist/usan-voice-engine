# === Production .env — store the FILLED copy in GCP Secret Manager (secret: usan-prod-env) ===
# Do NOT commit the filled version. The VM startup script writes it to /opt/usan/infra/.env.

# --- Images (set by the deploy workflow / operator) ---
GHCR_OWNER=gofrolist
# Set to an explicit immutable release tag (e.g. v1.4.0). Do NOT use "latest":
# the prod compose interpolation (${IMAGE_TAG:?...}) fails fast if this is unset.
IMAGE_TAG=__SET_TO_EXPLICIT_RELEASE_TAG__

# --- Domains (must have DNS A records -> VM static IP) ---
API_DOMAIN=api.usan.example
LIVEKIT_DOMAIN=lk.usan.example

# === Postgres ===
# Prod (Plan 4d): point DATABASE_URL at the Cloud SQL PRIVATE IP. Get the values from
#   terraform output db_private_ip   and   terraform output -raw db_password
#   DATABASE_URL=postgresql://usan:<db_password>@<db_private_ip>:5432/usan?ssl=require
# The POSTGRES_* vars below are only consumed by the LOCAL dev container, which is
# NOT started in prod (it sits behind the `localdb` compose profile).
POSTGRES_USER=usan
POSTGRES_PASSWORD=__STRONG_RANDOM__
POSTGRES_DB=usan
DATABASE_URL=postgresql://usan:__CLOUD_SQL_PASSWORD__@__CLOUD_SQL_PRIVATE_IP__:5432/usan?ssl=require

# === LiveKit SFU ===
LIVEKIT_API_KEY=__openssl rand -hex 16__
LIVEKIT_API_SECRET=__openssl rand -hex 32__
# Internal compose hop stays plaintext; external TLS is terminated by Caddy.
LIVEKIT_URL=ws://livekit:7880

# === Cartesia / Vertex AI ===
CARTESIA_API_KEY=
DEFAULT_CARTESIA_VOICE_ID=
# LLM on Vertex AI (HIPAA-BAA-covered) — no API key; ADC via the VM service account.
# "global": gemini-3.1-flash-lite is served on the global endpoint, not regional.
GCP_PROJECT=usan-retirement
VERTEX_LOCATION=global

# === Telnyx (SIP trunk) ===
TELNYX_SIP_USERNAME=
TELNYX_SIP_PASSWORD=
TELNYX_SIP_HOST=sip.telnyx.com
TELNYX_INBOUND_DID=
TELNYX_CALLER_ID=
# --- Telnyx Messaging (Phase 3 send_sms; feature-flagged OFF by default) ---
# Enable only after the messaging secret is in Secret Manager + the VM .env is
# refreshed BEFORE the v* tag deploy (deploy mechanics: secret not auto-refreshed).
TELNYX_MESSAGING_ENABLED=false
TELNYX_MESSAGING_API_KEY=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_FROM_NUMBER=
TELNYX_MESSAGING_API_URL=https://api.telnyx.com/v2
TELNYX_MESSAGING_TIMEOUT_S=10
# Auto-provisioned from the Telnyx SIP creds above on the first outbound dial —
# leave BLANK. Pin a specific ST_... trunk ID only to override auto-provisioning.
LIVEKIT_SIP_OUTBOUND_TRUNK_ID=

# === Service-to-service auth ===
JWT_SIGNING_KEY=__openssl rand -hex 32__
API_BASE_URL=http://api:8000

# === Operator/management API plane ===
# Authenticates the operator endpoints (/v1/elders, /v1/dnc, /v1/calls).
OPERATOR_API_KEY=__STRONG_RANDOM__
# Keep OpenAPI docs OFF in production.
DOCS_ENABLED=false
# Per-client request rate limiting (slowapi).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60/minute
# Reject webhooks whose signed timestamp is older than this many seconds.
WEBHOOK_MAX_AGE_S=300
# PHI retention purge horizon in days. Leave UNSET to disable the retention
# purge entirely (no automatic deletion of elder/call PHI).
# PHI_RETENTION_DAYS=90

# === Retry orchestrator (optional; compose supplies defaults) ===
RETRY_POLLER_ENABLED=true
RETRY_POLL_INTERVAL_S=30

# === Batch & scheduled calling (ships inert; spec §10) ===
# Staged enable (spec §10.3): flip CONCURRENCY_GATE_ENABLED=true first and watch
# the gauges against real retry traffic for a day; then SCHEDULER_POLLER_ENABLED=true
# with one test schedule; then a small (<=5-target) batch. Refresh the VM .env
# BEFORE the v* tag deploy — the deploy never re-fetches it.
# Invariant (startup-validated, spec §10.3): SCHEDULER_POLLER_ENABLED=true requires CONCURRENCY_GATE_ENABLED=true.
SCHEDULER_POLLER_ENABLED=false
SCHEDULER_POLL_INTERVAL_S=60
SCHEDULER_BATCH_SIZE=50
CONCURRENCY_GATE_ENABLED=false
MAX_CONCURRENT_CALLS=8
RESERVED_CONCURRENCY=2
MAX_AUTONOMOUS_CALLS_PER_ELDER_PER_DAY=2
AUTONOMOUS_DIALING_PAUSED=false

# === Outbound event webhooks (ships inert; spec 2026-06-10 §11) ===
# Enable sequence (spec §11.3): refresh the VM .env (flag still false) BEFORE the
# v* tag deploy (the deploy runs migration 0014 but never re-fetches the .env);
# then set WEBHOOK_DELIVERY_ENABLED=true + restart api; then
# POST /v1/webhook-endpoints (capture the secret from the 201 — shown exactly
# once); POST /v1/webhook-endpoints/{id}/test; confirm the ping row reaches
# 'delivered' via GET .../deliveries; then subscribe real events.
WEBHOOK_DELIVERY_ENABLED=false
# Optional tuning (compose supplies the defaults shown).
# WEBHOOK_DELIVERY_POLL_INTERVAL_S=10
# WEBHOOK_DELIVERY_TIMEOUT_S=10
# WEBHOOK_DELIVERY_CIRCUIT_BREAKER_THRESHOLD=10

# === Misc ===
LOG_LEVEL=INFO
AGENT_NAME=usan-agent

# === Call recording (LiveKit Egress -> GCS) ===
# Set to the `recordings_bucket` Terraform output. Egress writes here via the VM's
# service account (ADC); the API signs read URLs keylessly via IAM signBlob.
GCS_BUCKET=usan-call-recordings
# RECORDING_SIGNED_URL_TTL_S=3600

# === Observability — Grafana + Prometheus (MON-2) ===
# Grafana is reverse-proxied by Caddy at GRAFANA_DOMAIN and gated to an operator
# CIDR allowlist at L7 (GRAFANA_ALLOWED_CIDR). Prometheus is internal-only.
GRAFANA_DOMAIN=grafana.usan.example
# Space-separated CIDR allowlist for the Grafana subdomain (Caddy remote_ip).
# Use /32 for a single host, e.g. "203.0.113.4/32". 203.0.113.0/24 is a
# DOCUMENTATION range (RFC 5737) — REPLACE with your real operator CIDR before deploy
# or the Grafana UI will be unreachable from every real IP.
GRAFANA_ALLOWED_CIDR=203.0.113.4/32
# Grafana admin login password. Generate: terraform output -raw grafana_admin_password
GF_SECURITY_ADMIN_PASSWORD=__GRAFANA_ADMIN_PASSWORD__
# Read-only Postgres role password (grafana_ro). terraform output -raw grafana_ro_password
GF_POSTGRES_RO_PASSWORD=__GRAFANA_RO_DB_PASSWORD__
# Postgres host:port for the Grafana datasource. Prod = Cloud SQL private IP:5432
# (the same host as DATABASE_URL); dev = postgres:5432.
GRAFANA_DB_HOST=__CLOUD_SQL_PRIVATE_IP__:5432
# require in prod (Cloud SQL); disable for the dev bridge container.
GRAFANA_DB_SSLMODE=require

# === Admin UI — Google SSO console (Plan admin-5) ===
# The React admin console is reverse-proxied by Caddy at ADMIN_DOMAIN and gated to
# an operator CIDR allowlist at L7 (ADMIN_ALLOWED_CIDR) — same pattern as Grafana.
# Going live needs BOTH a v* tag (ships docker-compose.admin.yml) AND `terraform
# apply` (the admin.<domain> DNS record). Seed these onto the VM .env BEFORE the
# tag deploy — the deploy does not re-fetch the secret.
ADMIN_DOMAIN=admin.usan.example
# Space-separated CIDR allowlist for the admin subdomain (Caddy remote_ip). Use /32
# for a single host. 203.0.113.0/24 is a DOCUMENTATION range (RFC 5737) — REPLACE
# with your real operator CIDR before deploy or the console is unreachable.
ADMIN_ALLOWED_CIDR=203.0.113.4/32
# Google OAuth 2.0 Web client (GCP console -> APIs & Services -> Credentials). The
# authorized redirect URI MUST be exactly https://${ADMIN_DOMAIN}/v1/auth/callback
# and must be registered on the client (manual GCP step — see infra/README.md).
GOOGLE_OAUTH_CLIENT_ID=__GOOGLE_OAUTH_CLIENT_ID__
GOOGLE_OAUTH_CLIENT_SECRET=__GOOGLE_OAUTH_CLIENT_SECRET__
GOOGLE_OAUTH_REDIRECT_URI=https://admin.usan.example/v1/auth/callback
# Optional G Suite hosted-domain restriction (the `hd` claim). Blank = any Google
# account on the allow-list.
# GOOGLE_OAUTH_HD=usanretirement.com
# Comma-separated emails seeded as role=admin on first boot (the initial allow-list).
# After boot, manage the allow-list in the UI (Admin users screen).
ADMIN_BOOTSTRAP_EMAILS=ops@usanretirement.com
# Session cookie lifetime (seconds) and Secure flag. Keep SESSION_COOKIE_SECURE=true
# in prod (Caddy terminates TLS). Only local http dev sets it false.
# ADMIN_SESSION_TTL_S=28800
SESSION_COOKIE_SECURE=true
# Where /v1/auth/callback sends the browser after login (the SPA root).
# ADMIN_POST_LOGIN_REDIRECT=/
