# Security response headers for the browser-facing planes. Applied to the
# Cloudflare-proxied sites (admin/api/grafana). The CSP is scoped to the admin
# SPA's real origins; if a future asset origin is added, widen it here.
#
# Ships as Content-Security-Policy-Report-Only first (the snippet's own
# recommendation): the served admin build is known to exercise two directives
# that must NOT break under enforcement, so we observe report-only across the
# cutover, then promote to the enforcing `Content-Security-Policy` header once
# the console is clean. The policy is already written to allow both cases:
#   - script-src carries the sha256 hash of the inline theme-init block in
#     apps/admin-ui/dist/index.html (the pre-paint anti-FOUC script). Without
#     it an enforcing `script-src 'self'` would block that inline <script>,
#     reintroducing the very flash-of-wrong-theme it exists to prevent. If that
#     inline block changes, recompute the hash (it is the base64 sha256 of the
#     exact bytes between <script> and </script>).
#   - media-src allows https://storage.googleapis.com so RecordingPlayer's
#     <audio src> (a presigned GCS recording URL from the API's
#     object_storage.generate_signed_url) can load; media has no default-src
#     'self' fallback that would otherwise block the cross-origin recording.
(security_headers) {
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Content-Security-Policy-Report-Only "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'sha256-2LGxY21tnJOtIvjiiSPWY3DCRtf00gIB3ndHy3XHHgQ='; connect-src 'self'; media-src 'self' https://storage.googleapis.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		-Server
	}
}

# {$API_DOMAIN} and {$LIVEKIT_DOMAIN} come from the Caddy container env.
{$API_DOMAIN} {
	encode zstd gzip
	import security_headers
	# Cap request bodies at the edge so the unauthenticated, signature-gated webhook
	# routes (/v1/webhooks/telnyx, /v1/webhooks/livekit) can't be used to exhaust API
	# memory with a giant POST before the signature check reads the body. 1MB is ample
	# for every legitimate plane (webhook JSON, agent tool calls, operator commands).
	request_body {
		max_size 1MB
	}
	# The operator/management endpoints (/v1/contacts, /v1/dnc, /v1/calls) are
	# authenticated at the app layer via OPERATOR_API_KEY. An operator may add a
	# defense-in-depth IP allowlist for those paths here (e.g. a matcher with
	# `remote_ip` + `abort`) — not required for correctness.
	#
	# /metrics is the internal Prometheus scrape endpoint (the prometheus
	# container hits api:8000/metrics over the bridge). It must never be served
	# at the public edge — block it here (Caddy otherwise proxies the whole host).
	@metrics path /metrics
	respond @metrics 403

	# The admin-console plane (session-cookie auth) and the Google-SSO endpoints are
	# served ONLY via the CIDR-gated admin.<domain> origin below. Block them on this
	# ungated public api host so the admin plane has a single gated entry point
	# (defense in depth: a stolen session cookie can't be replayed off-CIDR here, and
	# the OAuth routes aren't probeable). The SPA + /v1 are same-origin on admin.<domain>;
	# the agent (/v1/runtime, /v1/calls/*) and operator (/v1/contacts, /v1/dnc, /v1/calls)
	# planes do not use these prefixes, so nothing legitimate is blocked.
	@adminplane path /v1/admin/* /v1/auth/*
	respond @adminplane 403

	reverse_proxy api:8000 {
		# Overwrite X-Forwarded-For with the direct client so the API rate
		# limiter keys on the real (non-spoofable) caller IP, not this proxy's.
		header_up X-Forwarded-For {remote_host}
	}
}

{$LIVEKIT_DOMAIN} {
	# livekit runs on the host network in prod (Plan 4e C1), so the compose-DNS
	# name `livekit` no longer resolves from this bridge container. Reach it via
	# the host gateway (caddy maps host.docker.internal:host-gateway in the TLS
	# overlay). This Caddyfile is prod-only (mounted solely by the caddy service).
	reverse_proxy host.docker.internal:7880
}

{$GRAFANA_DOMAIN} {
	encode zstd gzip
	import security_headers
	# Operator-CIDR allowlist enforced at L7 (443 is shared across api/lk/grafana
	# by SNI, so this cannot be a VM firewall rule). Anyone outside the CIDR gets
	# 403; allowed clients hit Grafana (which also requires its own login).
	@operator remote_ip {$GRAFANA_ALLOWED_CIDR}
	handle @operator {
		reverse_proxy grafana:3000
	}
	respond 403
}

{$ADMIN_DOMAIN} {
	encode zstd gzip
	import security_headers
	# Operator-CIDR allowlist enforced at L7 (443 is SNI-shared across all sites,
	# so this cannot be a VM firewall rule). Outside the CIDR -> 403. The admin SPA
	# and the API share THIS origin, so the SameSite=Strict session cookie set by
	# /v1/auth works (no cross-site cookie, no CORS).
	@operator remote_ip {$ADMIN_ALLOWED_CIDR}
	handle @operator {
		# Same-origin API: admin/auth/runtime endpoints go to the api container.
		@api path /v1/*
		handle @api {
			reverse_proxy api:8000 {
				# Real (non-spoofable) client IP for the API rate limiter.
				header_up X-Forwarded-For {remote_host}
			}
		}
		# Everything else is the React SPA static container (client-side routing is
		# handled inside that container via try_files -> /index.html).
		handle {
			reverse_proxy admin-ui:8080
		}
	}
	respond 403
}
