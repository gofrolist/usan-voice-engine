# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
project_id        = "your-gcp-project-id"
region            = "us-east1"
zone              = "us-east1-b"
ssh_user          = "usan"
ssh_public_key    = "ssh-ed25519 AAAA... you@host"
operator_ssh_cidr = "203.0.113.4/32" # your workstation IP /32
recordings_bucket = "your-globally-unique-bucket" # e.g. usan-retirement-call-recordings

# REQUIRED: Telnyx SIP SIGNALING source ranges (where inbound INVITEs come from) — NOT
# the media/RTP CIDRs. US: 192.76.120.10 + 64.16.250.10 (https://sip.telnyx.com → "SIP
# signaling addresses"); the /24s give headroom. Putting the media CIDRs here silently
# drops every inbound call ("your call cannot be completed"). Wrong/stale = broken inbound.
telnyx_sip_signaling_source_ranges = [
  "192.76.120.0/24", "64.16.250.0/24",
]

# recording_nearline_days  = 30
# recording_retention_days = 365

# Observability (Plan 4e B). Set operator_alert_email to enable Cloud Monitoring
# alerts (API-down uptime check + CPU/mem/disk); empty = no alerting. The PHI-access
# audit log bucket retention defaults to 2190 days (6yr, locked) — override here.
operator_alert_email = "you@example.com"
# audit_log_retention_days = 2190

# Cloudflare DNS automation (optional). Set BOTH to have Terraform create the
# api.<domain> and lk.<domain> A records (proxied=false) pointing at the VM IP.
# Leave empty to manage DNS by hand.
# cloudflare_api_token = "cfut_..."   # dash.cloudflare.com -> My Profile -> API Tokens -> "Edit zone DNS"
# cloudflare_zone_id   = "..."        # CF dashboard -> domain overview -> right sidebar
