{
	# No TLS at this layer (the edge Caddy terminates TLS); no admin API; do not
	# persist autosaved config — keeps a non-root Caddy starting cleanly.
	admin off
	auto_https off
	persist_config off
}

:8080 {
	root * /srv
	encode zstd gzip
	# SPA client-side routing: serve the requested file if it exists, else the
	# index shell. A bare `try_files {path} /index.html` strips the asset cache
	# semantics, so cache headers are set explicitly below.
	try_files {path} /index.html
	file_server
	# Fingerprinted build assets are immutable; the HTML shell must never cache so
	# a new deploy is picked up immediately.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"
	header /index.html Cache-Control "no-cache"
}
